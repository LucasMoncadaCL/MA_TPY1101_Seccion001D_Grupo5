APP_DB_ENV=supabase

# Supabase DB (usado por el backend en compose de Producto)
DB_SUPABASE_HOST=aws-1-us-east-1.pooler.supabase.com
DB_SUPABASE_PORT=5432
DB_SUPABASE_NAME=postgres
DB_SUPABASE_USER=postgres.ekqbucfoygimzgxupdhm
DB_SUPABASE_PASSWORD=replace_me
DB_SUPABASE_SSL_MODE=require

# Docker local DB (opcional si APP_DB_ENV=docker)
DB_DOCKER_HOST=postgres
DB_DOCKER_PORT=5432
DB_DOCKER_NAME=panol
DB_DOCKER_USER=panol_user
DB_DOCKER_PASSWORD=replace_me
DB_DOCKER_SSL_MODE=disable

BACKEND_PORT=18080
FRONTEND_PORT=18081
VITE_API_BASE_URL=http://localhost:18080

JOOQ_DB_URL=jdbc:postgresql://aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
