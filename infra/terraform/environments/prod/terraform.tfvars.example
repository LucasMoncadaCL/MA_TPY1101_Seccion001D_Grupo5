
gcp_project_id           = "replace-me-prod-project"
region                   = "us-central1"
environment              = "prod"
artifact_registry_location = "us-central1"

backend_image            = "us-central1-docker.pkg.dev/replace-me-prod-project/panol-apps-prod/backend:latest"
frontend_image           = "us-central1-docker.pkg.dev/replace-me-prod-project/panol-apps-prod/frontend:latest"

supabase_db_host         = "aws-1-us-east-1.pooler.supabase.com"
supabase_db_port         = 5432
supabase_db_name         = "postgres"
supabase_db_user         = "postgres.replace_me"

app_security_enabled              = true
app_auth_max_failed_attempts      = 5
app_auth_lock_minutes             = 15
app_auth_jwt_issuer               = "panol-backend-prod"
app_auth_jwt_expiration_seconds   = 3600

backend_domain           = ""
frontend_domain          = ""

backend_min_instances    = 1
backend_max_instances    = 5
frontend_min_instances   = 1
frontend_max_instances   = 5

# Optional: set to create/update the MONGODB_URI secret version from Terraform.
# Leave empty to manage secret versions outside Terraform.
mongodb_uri_secret_value = ""
