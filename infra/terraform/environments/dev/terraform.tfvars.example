gcp_project_id           = "replace-me-dev-project"
region                   = "us-central1"
environment              = "dev"
artifact_registry_location = "us-central1"

backend_image            = "us-central1-docker.pkg.dev/replace-me-dev-project/panol-apps-dev/backend:latest"
frontend_image           = "us-central1-docker.pkg.dev/replace-me-dev-project/panol-apps-dev/frontend:latest"

supabase_db_host         = "aws-1-us-east-1.pooler.supabase.com"
supabase_db_port         = 5432
supabase_db_name         = "postgres"
supabase_db_user         = "postgres.replace_me"

backend_domain           = ""
frontend_domain          = ""

# Cost-optimized dev profile (scale to zero)
backend_min_instances    = 0
backend_max_instances    = 1
backend_timeout_seconds  = 120
backend_concurrency      = 40

frontend_min_instances   = 0
frontend_max_instances   = 1
frontend_timeout_seconds = 60
frontend_concurrency     = 40
